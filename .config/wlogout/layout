{
  "label" : "lock",
  "action" : "hyprlock"
  "keybind" : "l",
  "circular" : true
}
{
  "label" : "logout",
  "action" : "hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit",
  "keybind" : "e",
  "circular": true
}
{
  "label" : "shutdown",
  "action" : "hyprshutdown -p 'systemctl poweroff'",
  "keybind" : "s",
  "circular": true
}
{
  "label" : "hibernate",
  "action" : "systemctl hibernate",
  "keybind" : "h",
  "circular": true
}
{
  "label" : "reboot",
  "action" : "systemctl reboot",
  "keybind" : "r",
  "circular": true
}
