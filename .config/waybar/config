{
    "layer": "top",
    "opacity": 0.99,
    "exclusive": true,
    "height": 30,
    "spacing": 12,
    "margin-left": 6,
    "margin-right": 6,
    "margin-top": 6,
    "reload-style-on-change": true,
    "modules-left": [
        "group/hardware",
        "privacy",
        "memory",
        "cpu",
        "temperature",
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "niri/workspaces",
        "pulseaudio",
        "battery",
        "power-profiles-daemon",
        "network",
        "tray"
    ],

    "group/hardware": {
        "orientation": "horizontal",
        "drawer": {
            "click-to-reveal": true,
            "transition-duration": 350,
            "transition-left-to-right": true
        },
        "modules": [
            "custom/tux",
            "custom/monitor",
            "custom/display",
            "custom/look",
            "custom/logout"
        ]
    },

    "custom/tux": {
        "format": "’īā",
        "tooltip-format": "BTW...."
    },

    "custom/look": {
        "format": "ŅŁæ",
        "on-click": "~/bin/toggle nwg-look",
        "tooltip-format": "GTK Theme/Icon Settings"
    },

    "custom/logout": {
        "format": "’Ćæ",
        "on-click": "wlogout -b 5 -T 400px -B 400px -p layer-shell",
        "tooltip-format": "Session management."
    },

    "custom/power": {
        "exec": "tlp-stat --mode",
        "format": "¾░éä",
        "interval": 5,
        "on-click": "~/bin/toggle-power",
        "tooltip-format": "Change power-profile.  Currently({})"
    },

    "custom/monitor": {
        "format": "Ņ¼ā",
        "on-click": "resources",
        "tooltip-format": "Sytem Monitor"
    },

    "custom/display": {
        "format": "¾░Ź╣",
        "on-click": "nwg-displays",
        "tooltip-format": "Configure display(s)"
    },

    "custom/info": {
        "format": "’æē",
        "on-click": "~/bin/toggle hyprsysteminfo",
        "tooltip-format": ""
    },

    "privacy": {
        "icon-spacing": 4,
        "icon-size": 18,
        "transition-duration": 250,
        "modules": [
            {
                "type": "screenshare",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-out",
                "tooltip": true,
                "tooltip-icon-size": 24
            },
            {
                "type": "audio-in",
                "tooltip": true,
                "tooltip-icon-size": 24
            }
        ]
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate",
        "persistent-workspaces": {
            "*": 4
        }
    },

    "niri/workspaces": {
        "transition-duration": 0,
        "format": "{value}"
    },

    "mpd": {
        "on-click": "rmpc togglepause",
        "on-click-right": "pkill rmpc || footclient rmpc",

        "format": "{stateIcon}    {artist}/{title}",
        "format-disconnected": "MPD - Disconnected",
        "format-stopped": "MPD - Stopped",
        "interval": 10,
        "consume-icons": {
            "on": "’āä "
        },
        "random-icons": {
            "off": "’ü┤",
            "on": ""
        },
        "repeat-icons": {
            "on": "’Ć×"
        },
        "single-icons": {
            "on": "’Ć×1 "
        },
        "state-icons": {
            "paused": "’üī",
            "playing": "’üŗ"
        },
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    },

    "clock": {
        "timezone": "Pacific/Auckland",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%a %d %b - %I:%M %p}"
    },

    "cpu": {
        "format": "cpu: {usage}%",
        "tooltip": false,
        "on-click": "",
        "interval": 1
    },

    "memory": {
        "tooltip": false,
        "format": "mem: {}%",
        "on-click": ""
    },

    "temperature": {
        "hwmon-path":
        [
            "/sys/bus/platform/devices/coretemp.0/hwmon/hwmon6/temp2_input",
            "/sys/bus/platform/devices/coretemp.0/hwmon/hwmon7/temp2_input"
        ],
        "format": "{temperatureC}┬░C",
        "tooltip": false,
    },

    "battery": {
        "states": {
            "good": 35,
            "warning": 15,
            "critical": 5
        },
        "format": "{capacity}%  {icon}",
        "format-charging": "{capacity}% (¾▒Éŗ) {icon}",
        "format-full": "’ēĆ",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
        "interval": 3,
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power Profile: {profile}\nDriver: {driver}",
        "tooltip" : true,
        "format-icons": {
            "default": "¾▒Éŗ",
            "performance": "¾▒Éŗ",
            "balanced": "¾░Śæ",
            "power-saver": "¾░ī¬"
        }
    },

    "network": {
        "format-wifi": "{essid} ({signalStrength}%)",
        "format-ethernet": "{ipaddr}/{cidr}",
        "tooltip-format": "{ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "Disconnected ŌÜĀ",
        "format-alt": "{ifname}: {ipaddr}/{cidr} (gateway: {gwaddr})",
        "on-click-right": "iwgtk"
    },

    "pulseaudio": {
        "on-click": "pavucontrol",
        "format": "{icon}",
        "tooltip-format": "{desc}: {volume}%",
        "format-muted": "’Ü®",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        }
    }
}
