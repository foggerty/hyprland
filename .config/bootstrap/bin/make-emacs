#!/bin/sh

set -o errexit

mkdir -p ~/dev

pushd ~/dev

if [[ ! -d "emacs" ]]; then
    git clone https://github.com/emacs-mirror/emacs --depth=1 --branch=emacs-30
    pushd emacs

else
    pushd emacs
fi

make clean

git pull --rebase

./autogen.sh

./configure --with-pgtk \
            --with-tree-sitter \
            --with-sound=no \
            --with-imagemagick \
            --without-selinux \
            --without-gconf \
            --without-gsettings \
            --without-xinput2 \
            --disable-gc-mark-trace \
            --without-xaw3d \
            --without-xim \
            --without-xdbe \
            --with-small-ja-dic


#export CFLAGS="-march=native -O2 -pipe -fomit-frame-pointer"
export CFLAGS="-march=native -O2 -pipe"
export MAKEFLAGS="-j$(nproc)"

make && sudo make install

popd
popd
